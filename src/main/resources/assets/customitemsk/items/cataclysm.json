{
  "model": {
    "type": "minecraft:condition",
    "property": "minecraft:using_item",
    "on_true": {
      "type": "minecraft:range_dispatch",
      "property": "minecraft:use_duration",
      "scale": 0.05,
      "fallback": {
        "type": "minecraft:model",
        "model": "customitemsk:item/cataclysm_stage1"
      },
      "entries": [
        {
          "threshold": 1.25,
          "model": {
            "type": "minecraft:model",
            "model": "customitemsk:item/cataclysm_stage2"
          }
        },
        {
          "threshold": 3.0,
          "model": {
            "type": "minecraft:model",
            "model": "customitemsk:item/cataclysm_stage3"
          }
        }
      ]
    },
    "on_false": {
      "type": "minecraft:model",
      "model": "customitemsk:item/cataclysm"
    }
  }
}
